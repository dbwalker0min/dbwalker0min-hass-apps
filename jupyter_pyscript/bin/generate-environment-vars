#!/usr/bin/env python3
import os
import json
import shlex
from jupyter_server.auth import passwd

OPTION_FILE = "/data/options.json"

if not os.path.isfile(OPTION_FILE):
    exit(0)  # No options file, so just exit with no output (env vars will be empty)

def coalesce_str(val, default: str) -> str:
    """Treat None / empty / whitespace-only as default; otherwise stringify."""
    if val is None:
        return default
    if isinstance(val, str):
        s = val.strip()
        return default if s == "" else val
    return str(val)

with open(OPTION_FILE, "r", encoding="utf-8") as f:
    options = json.load(f)

# Always define HA env vars (required parameters; values come directly from options)
HASS_HOST = options.get("hass_host", "")
HASS_URL  = options.get("hass_url",  "")
HASS_TOKEN = options.get("hass_token", "")

# Build NOTEBOOK_ARGS deterministically
arguments = shlex.split(coalesce_str(options.get("extra_args"), ""))

notebook_dir = coalesce_str(options.get("notebook_dir"), "")
if notebook_dir:
    arguments.append(f"--ServerApp.root_dir={notebook_dir}")

pw  = coalesce_str(options.get("jupyter_password"), "")
tok = coalesce_str(options.get("jupyter_token"), "")

# Important: coalesce_str("" , "") -> "" so this is safe.
if pw:
    arguments.append(f"--PasswordIdentityProvider.hashed_password={passwd(pw)}")
elif tok:
    arguments.append(f"--IdentityProvider.token={tok}")
# else: Jupyter will auto-generate a token

NOTEBOOK_ARGS = shlex.join(arguments)

env_vars = {
    "HASS_HOST": HASS_HOST,
    "HASS_URL": HASS_URL,
    "HASS_TOKEN": HASS_TOKEN,
    "NOTEBOOK_ARGS": NOTEBOOK_ARGS,
}

for k, v in env_vars.items():
    print(f"export {k}={shlex.quote(v)}")